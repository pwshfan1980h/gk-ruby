<% content_for :title, "Administrator sign in" %>

<div class="mx-auto w-full max-w-md py-16">
  <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
    <p class="text-sm font-semibold uppercase tracking-widest text-blue-700">Private administration</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950">Sign in</h1>
    <p class="mt-2 text-sm leading-6 text-slate-600">Use the administrator account issued for your organization.</p>

    <%= form_with url: session_url, class: "mt-7 space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, class: "block text-sm font-semibold text-slate-800" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "admin@example.org", value: params[:email_address], class: "mt-2 block w-full rounded-lg border border-slate-300 px-3 py-2.5 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div>
        <%= form.label :password, class: "block text-sm font-semibold text-slate-800" %>
        <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72, class: "mt-2 block w-full rounded-lg border border-slate-300 px-3 py-2.5 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <%= form.submit "Sign in", class: "w-full rounded-lg bg-blue-700 px-4 py-3 font-semibold text-white hover:bg-blue-800" %>
    <% end %>

    <%= link_to "Forgot your password?", new_password_path, class: "mt-5 inline-flex text-sm font-semibold text-blue-700 hover:text-blue-900" %>
  </div>
</div>
