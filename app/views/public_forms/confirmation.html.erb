<% content_for :title, "Complaint received" %>

<div class="mx-auto w-full max-w-2xl py-16">
  <div class="rounded-2xl border border-emerald-200 bg-white p-8 shadow-sm sm:p-10">
    <div class="flex size-12 items-center justify-center rounded-full bg-emerald-100 text-2xl text-emerald-800" aria-hidden="true">✓</div>
    <h1 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950">Complaint received</h1>
    <p class="mt-3 whitespace-pre-line leading-7 text-slate-600"><%= @form_version.confirmation_message.presence || "Thank you. Your complaint has been submitted." %></p>
    <div class="mt-7 rounded-xl bg-slate-100 p-5">
      <p class="text-sm font-medium text-slate-600">Your reference number</p>
      <p class="mt-1 font-mono text-xl font-bold tracking-wide text-slate-950"><%= @reference_number %></p>
    </div>
    <%= link_to "Return to the form", public_form_path(organization_slug: @organization.slug), class: "mt-7 inline-flex font-semibold text-blue-700 hover:text-blue-900" %>
  </div>
</div>
