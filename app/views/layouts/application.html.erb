<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Gk Ruby" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Gk Ruby">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <% if notice.present? || alert.present? %>
      <div class="fixed inset-x-0 top-4 z-50 mx-auto w-[calc(100%-2rem)] max-w-2xl rounded-xl border px-4 py-3 text-sm font-semibold shadow-lg <%= alert.present? ? "border-red-200 bg-red-50 text-red-900" : "border-emerald-200 bg-emerald-50 text-emerald-900" %>" role="status">
        <%= alert.presence || notice %>
      </div>
    <% end %>
    <main class="container mx-auto px-5">
      <%= yield %>
    </main>
  </body>
</html>
