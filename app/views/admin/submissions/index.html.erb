<% content_for :title, "Submissions" %>

<div class="mx-auto w-full max-w-7xl py-8">
  <div class="flex flex-col justify-between gap-4 border-b border-slate-200 pb-6 md:flex-row md:items-end">
    <div>
      <%= link_to "← #{current_organization.name}", admin_organization_path(current_organization), class: "text-sm font-semibold text-blue-700" %>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950">Submissions</h1>
      <p class="mt-2 text-slate-600"><%= number_with_delimiter(@total_count) %> matching submissions</p>
    </div>
    <%= link_to "Export filtered CSV", export_admin_organization_submissions_path(current_organization, request.query_parameters), class: "rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
  </div>

  <%= form_with url: admin_organization_submissions_path(current_organization), method: :get, class: "mt-6 grid gap-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm md:grid-cols-5" do |form| %>
    <div>
      <%= form.label :reference_number, "Reference", class: "block text-xs font-bold uppercase tracking-wide text-slate-500" %>
      <%= form.text_field :reference_number, value: params[:reference_number], placeholder: "GK-…", class: "mt-2 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :status, class: "block text-xs font-bold uppercase tracking-wide text-slate-500" %>
      <%= form.select :status, [["Any status", ""]] + Submission.statuses.keys.map { |status| [status.humanize, status] }, { selected: params[:status] }, class: "mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" %>
    </div>
    <div>
      <%= form.label :from, class: "block text-xs font-bold uppercase tracking-wide text-slate-500" %>
      <%= form.date_field :from, value: params[:from], class: "mt-2 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :to, class: "block text-xs font-bold uppercase tracking-wide text-slate-500" %>
      <%= form.date_field :to, value: params[:to], class: "mt-2 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </div>
    <div class="flex items-end gap-2">
      <%= form.submit "Filter", class: "rounded-lg bg-slate-950 px-4 py-2 font-semibold text-white" %>
      <%= link_to "Clear", admin_organization_submissions_path(current_organization), class: "px-2 py-2 text-sm font-semibold text-slate-600" %>
    </div>
  <% end %>

  <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <% if @submissions.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50 text-left text-xs font-bold uppercase tracking-wide text-slate-500">
            <tr><th class="px-5 py-3">Reference</th><th class="px-5 py-3">Submitted</th><th class="px-5 py-3">Version</th><th class="px-5 py-3">Status</th><th class="px-5 py-3"><span class="sr-only">Open</span></th></tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @submissions.each do |submission| %>
              <tr>
                <td class="whitespace-nowrap px-5 py-4 font-mono text-sm font-semibold"><%= submission.reference_number %></td>
                <td class="whitespace-nowrap px-5 py-4 text-sm text-slate-600"><%= time_tag submission.submitted_at, submission.submitted_at.to_fs(:long) %></td>
                <td class="px-5 py-4 text-sm text-slate-600">v<%= submission.form_version.version_number %></td>
                <td class="px-5 py-4"><span class="rounded-full px-2.5 py-1 text-xs font-bold <%= submission_status_classes(submission.status) %>"><%= submission.status.humanize %></span></td>
                <td class="px-5 py-4 text-right"><%= link_to "Review", admin_organization_submission_path(current_organization, submission), class: "text-sm font-semibold text-blue-700 hover:text-blue-900" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="p-12 text-center"><h2 class="font-semibold text-slate-900">No submissions found</h2><p class="mt-1 text-sm text-slate-500">Try changing or clearing the filters.</p></div>
    <% end %>
  </div>

  <nav class="mt-6 flex justify-between" aria-label="Submission pages">
    <% if @page > 1 %><%= link_to "← Previous", admin_organization_submissions_path(current_organization, request.query_parameters.merge(page: @page - 1)), class: "font-semibold text-blue-700" %><% else %><span></span><% end %>
    <% if @page * Admin::SubmissionsController::PAGE_SIZE < @total_count %><%= link_to "Next →", admin_organization_submissions_path(current_organization, request.query_parameters.merge(page: @page + 1)), class: "font-semibold text-blue-700" %><% end %>
  </nav>
</div>
