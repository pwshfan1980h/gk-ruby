<% content_for :title, "#{current_organization.name} administration" %>

<div class="mx-auto w-full max-w-6xl">
  <div class="flex flex-col justify-between gap-5 border-b border-slate-200 pb-7 md:flex-row md:items-end">
    <div>
      <p class="text-sm font-semibold uppercase tracking-widest text-blue-700">Administration</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950"><%= current_organization.name %></h1>
      <p class="mt-2 text-slate-600">Manage the public complaint form and review responses.</p>
    </div>
    <%= button_to "Sign out", session_path, method: :delete, class: "rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
  </div>

  <div class="mt-8 grid gap-5 md:grid-cols-3">
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:col-span-2">
      <h2 class="text-lg font-semibold text-slate-950">Complaint form</h2>
      <p class="mt-2 text-sm text-slate-600"><%= @form&.published_version ? "A public version is available." : "No version has been published yet." %></p>
      <p class="mt-1 text-sm text-slate-500"><%= @form&.draft_version ? "Draft version #{@form.draft_version.version_number} is ready to edit." : "There is no editable draft." %></p>
      <% if @form %>
        <div class="mt-5 flex flex-wrap gap-3">
          <%= link_to "Edit draft", edit_admin_organization_form_path(current_organization), class: "rounded-lg bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800" %>
          <%= link_to "Open public form", public_form_path(organization_slug: current_organization.slug), target: "_blank", class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
        </div>
      <% end %>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-slate-500">Submissions</p>
      <p class="mt-2 text-4xl font-semibold tracking-tight text-slate-950"><%= current_organization.submissions.count %></p>
      <p class="mt-1 text-sm text-slate-500"><%= current_organization.submissions.new_submission.count %> awaiting review</p>
      <%= link_to "Review submissions", admin_organization_submissions_path(current_organization), class: "mt-5 inline-flex text-sm font-semibold text-blue-700 hover:text-blue-900" %>
    </section>
  </div>

  <% if current_membership.owner? %>
    <section class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-950">Administrators</h2>
      <p class="mt-1 text-sm text-slate-600">Invite one additional administrator. Invitations expire after seven days.</p>
      <div class="mt-5 divide-y divide-slate-100 rounded-xl border border-slate-200">
        <% current_organization.memberships.active.includes(:user).each do |membership| %>
          <div class="flex items-center justify-between gap-4 p-4">
            <div>
              <p class="font-semibold text-slate-900"><%= membership.user.name %></p>
              <p class="text-sm text-slate-500"><%= membership.user.email_address %> · <%= membership.role.humanize %></p>
            </div>
            <% unless membership == current_membership %>
              <%= button_to "Deactivate", admin_organization_membership_path(current_organization, membership), method: :delete, form: { data: { turbo_confirm: "Remove this administrator's access?" } }, class: "text-sm font-semibold text-red-700 hover:text-red-900" %>
            <% end %>
          </div>
        <% end %>
      </div>
      <%= form_with url: admin_organization_invitations_path(current_organization), scope: :invitation, class: "mt-5 flex max-w-xl flex-col gap-3 sm:flex-row" do |form| %>
        <%= form.email_field :email_address, required: true, autocomplete: "email", placeholder: "colleague@example.com", class: "min-w-0 flex-1 rounded-lg border border-slate-300 px-3 py-2 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
        <%= form.submit "Send invitation", class: "rounded-lg bg-blue-700 px-4 py-2 font-semibold text-white hover:bg-blue-800" %>
      <% end %>
    </section>
  <% end %>
</div>
