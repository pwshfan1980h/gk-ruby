<% content_for :title, "Choose a new password" %>

<div class="mx-auto w-full max-w-md py-16">
  <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
    <h1 class="text-3xl font-semibold tracking-tight text-slate-950">Choose a new password</h1>
    <p class="mt-2 text-sm text-slate-600">Use at least 12 characters. Existing sessions will be signed out.</p>
    <%= form_with url: password_path(params[:token]), method: :put, class: "mt-7 space-y-5" do |form| %>
      <div>
        <%= form.label :password, "New password", class: "block text-sm font-semibold text-slate-800" %>
        <%= form.password_field :password, required: true, minlength: 12, autocomplete: "new-password", maxlength: 72, class: "mt-2 block w-full rounded-lg border border-slate-300 px-3 py-2.5" %>
      </div>
      <div>
        <%= form.label :password_confirmation, "Confirm new password", class: "block text-sm font-semibold text-slate-800" %>
        <%= form.password_field :password_confirmation, required: true, minlength: 12, autocomplete: "new-password", maxlength: 72, class: "mt-2 block w-full rounded-lg border border-slate-300 px-3 py-2.5" %>
      </div>
      <%= form.submit "Save new password", class: "w-full rounded-lg bg-blue-700 px-4 py-3 font-semibold text-white hover:bg-blue-800" %>
    <% end %>
  </div>
</div>
