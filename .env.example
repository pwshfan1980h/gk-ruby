# Application identity and URL generation
APP_HOST=forms.example.org
APP_PROTOCOL=https
ASSUME_SSL=true
FORCE_SSL=true

# Rails and database secrets
RAILS_MASTER_KEY=replace-with-the-deployment-secret
DATABASE_URL=postgresql://gk_ruby:replace-me@database.example.org/gk_ruby_production

# Transactional administrator email
SMTP_ADDRESS=smtp.example.org
SMTP_PORT=587
SMTP_USERNAME=replace-me
SMTP_PASSWORD=replace-me
SMTP_AUTHENTICATION=plain
SMTP_STARTTLS=true
MAIL_FROM=gk-ruby@example.org

# Runtime sizing
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2
JOB_CONCURRENCY=1
SOLID_QUEUE_IN_PUMA=true
RAILS_LOG_LEVEL=info
